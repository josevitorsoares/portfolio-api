# -------------------------------------------------------
# APPLICATION CONFIGURATION
# -------------------------------------------------------

# Application environment mode
# Options: development, production, test
NODE_ENV="development"

# Server port number
# Default: 3333
PORT=3333

# API base path for versioning
# Used to define the API endpoint prefix for all routes
# Format: /api/v{version}
# Example: /api/v1 routes requests to version 2 of the API
API_PATH="/api/v1"

# Application base URL
# Used for generating links and redirects
APP_URL=""

# -------------------------------------------------------
# REDIS CONFIGURATION
# -------------------------------------------------------

# Redis is used for caching tracking data, reducing calls to the external API.
# Option 1: Use full URL with auth (recommended for production)
# REDIS_URL="redis://default:password@localhost:6379"

# Option 2: Use host, port and password separately (for local development)
REDIS_HOST="localhost"
REDIS_PORT=6379
# REDIS_PASSWORD=""  # Optional, only if Redis requires authentication

# -------------------------------------------------------
# TWITTER CONFIGURATION
# -------------------------------------------------------

TWITTER_API_URL="https://api.x.com/2"
TWITTER_ACCOUNT_ID=""
TWITTER_ACCESS_TOKEN=""

# -------------------------------------------------------
# TRACKING EXTERNAL API CONFIGURATION
# -------------------------------------------------------

TRACKING_API_URL="https://rastro-correios-api.zeabur.app/api/v2"
